# ===========================================
# logi-quiz 開発環境設定
# コピーして .env を作成: cp .env.example .env
# ===========================================

# --- Database ---
DATABASE_HOST=db
DATABASE_USERNAME=root
DATABASE_PASSWORD=password
DATABASE_NAME=api_development
DATABASE_PORT=3306

# --- Rails ---
RAILS_ENV=development
RAILS_MASTER_KEY=

# --- Seed Data ---
# seed実行時のユーザーパスワード（省略時: password123）
SEED_USER_PASSWORD=password123

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Vite) ---
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:3001
VITE_CONFIRM_SUCCESS_URL=http://localhost:3000/confirmation-success

# --- メール設定（Gmail SMTP） ---
# サインアップ確認メール等の送信に必要
# Gmailの場合: アプリパスワードを使用（https://myaccount.google.com/apppasswords）
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
